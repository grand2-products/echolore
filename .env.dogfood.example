# Dogfooding environment variables
#
# Copy this file:  cp .env.dogfood.example .env.dogfood
# Then edit .env.dogfood with your actual values.

# --- Ports (same defaults as dev to avoid collisions) ---
WEB_PORT=17760
API_PORT=17721
LIVEKIT_PORT=17722
DB_PORT=17724
VALKEY_PORT=17725
LIVEKIT_RTC_PORT_RANGE=17730-17750

# --- Secrets ---
DB_PASSWORD=dogfood_password
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
AUTH_SECRET=dogfood-auth-secret
ROOM_AI_WORKER_SECRET=dogfood-worker-secret

# --- AI (set your real key to test AI features) ---
GEMINI_API_KEY=
ENCRYPTION_KEY=
