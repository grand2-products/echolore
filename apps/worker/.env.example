# Worker application environment

NODE_ENV=development
API_PORT=17721
LIVEKIT_PORT=17722

ROOM_AI_WORKER_MODE=monitor
ROOM_AI_WORKER_SECRET=local-dev-worker-secret
ROOM_AI_POLL_INTERVAL_MS=15000
ROOM_AI_WEBHOOK_PORT=17727

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional overrides when you are not using localhost-based local dev:
# ROOM_AI_API_BASE_URL=https://api.example.com
# LIVEKIT_HOST=https://livekit.example.com
