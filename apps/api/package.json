{
  "name": "@corp-internal/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -e .env.local -- node ../../scripts/dev/run-api-dev.mjs",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@corp-internal/shared": "workspace:*",
    "@google-cloud/speech": "^6.7.0",
    "@google-cloud/vertexai": "^1.9.3",
    "@hono/auth-js": "^1.1.1",
    "@hono/node-server": "^1.13.8",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.4.3",
    "@langchain/community": "^1.1.23",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/google-vertexai": "^2.1.25",
    "@langchain/langgraph": "^1.2.2",
    "drizzle-orm": "^0.40.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^171.4.0",
    "hono": "^4.7.2",
    "langchain": "^1.2.31",
    "livekit-server-sdk": "^2.9.7",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.2",
    "pg": "^8.13.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
