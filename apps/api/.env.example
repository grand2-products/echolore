# API application environment

APP_TITLE=corp-internal
API_PORT=17721
WEB_PORT=17720
DB_PORT=17724
LIVEKIT_PORT=17722
NODE_ENV=development
API_NODE_ENV=development

DATABASE_URL=postgresql://wiki:wiki_password@localhost:17724/wiki
DB_PASSWORD=wiki_password

AUTH_ALLOWED_DOMAIN=grand2-products.com
AUTH_BYPASS=true
AUTH_VERIFY_URL=http://localhost:17726/oauth2/auth

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

GCS_BUCKET=corp-internal-files-dev
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS_HOST=/path/to/service-account.json

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

ROOM_AI_WORKER_SECRET=local-dev-worker-secret

# `PORT`, `CORS_ORIGIN`, `LIVEKIT_HOST`, and local `DATABASE_URL` are normalized
# from the port variables above during `pnpm dev` / `./dev.ps1`.
# Set the URL values explicitly only when you need non-localhost endpoints.
