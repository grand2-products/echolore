{
  "name": "echolore",
  "version": "0.1.0",
  "private": true,
  "description": "EchoLore — AI-powered knowledge & meeting platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:i18n": "node ./scripts/dev/check-web-i18n.mjs",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:daily": "powershell -ExecutionPolicy Bypass -File ./dev.ps1",

    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:push": "pnpm --filter api db:push",
    "db:studio": "pnpm --filter api db:studio",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "dotenv-cli": "^11.0.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.17",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6"
    }
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
