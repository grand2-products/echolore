# ===========================================
# Corp Internal - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://wiki:wiki_password@localhost:5432/wiki
DB_PASSWORD=wiki_password

# ===========================================
# API Server Configuration
# ===========================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ===========================================
# Next.js Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ===========================================
# LiveKit Configuration
# ===========================================
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ===========================================
# Google Cloud Platform Configuration
# ===========================================
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET=corp-internal-files-dev
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ===========================================
# OAuth2 Proxy Configuration (for Google SSO)
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
COOKIE_SECRET=generate-a-random-32-char-string

# ===========================================
# AI Services (Optional - for Room mode)
# ===========================================
# Google Cloud Speech-to-Text (already included in GCP)
# Vertex AI for summarization (already included in GCP)

