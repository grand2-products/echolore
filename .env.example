# ===========================================
# Corp Internal - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# App Branding
# ===========================================
APP_TITLE=corp-internal
NEXT_PUBLIC_APP_TITLE=corp-internal
NEXT_PUBLIC_APP_TAGLINE=Internal collaboration platform

# ===========================================
# Database Configuration
# ===========================================
DB_PASSWORD=wiki_password
DB_PORT=17724
DATABASE_URL=postgresql://wiki:wiki_password@localhost:17724/wiki

# ===========================================
# API Server Configuration
# ===========================================
WEB_PORT=17720
API_PORT=17721
LIVEKIT_PORT=17722
LIVEKIT_SIGNAL_PORT=17723
VALKEY_PORT=17725
OAUTH_PROXY_PORT=17726
LIVEKIT_RTC_PORT_RANGE=17730-17930
PORT=17721
NODE_ENV=development
CORS_ORIGIN=http://localhost:17720
API_IMAGE=gcr.io/your-project-id/corp-internal-api:latest
WEB_IMAGE=gcr.io/your-project-id/corp-internal-web:latest
GOOGLE_APPLICATION_CREDENTIALS_HOST=/path/to/service-account.json

# ===========================================
# Next.js Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:17721
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:17722

# ===========================================
# LiveKit Configuration
# ===========================================
LIVEKIT_HOST=http://localhost:17722
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ===========================================
# Google Cloud Platform Configuration
# ===========================================
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET=corp-internal-files-dev
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ===========================================
# OAuth2 Proxy Configuration (for Google SSO)
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
COOKIE_SECRET=generate-a-random-32-char-string

# OAuth2 Proxy Settings
OAUTH_COOKIE_SECURE=true  # 本番では必ず true
OAUTH_REDIRECT_URL=http://localhost:17726/oauth2/callback

# OAuth2 Proxy 経由公開時は 4180 を指定
CORS_ORIGIN=http://localhost:4180

# ===========================================
# AI Services (Optional - for Room mode)
# ===========================================
# Google Cloud Speech-to-Text (already included in GCP)
# Vertex AI for summarization (already included in GCP)
