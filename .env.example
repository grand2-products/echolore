# Root dev orchestration environment
#
# Primary application env files now live here:
# - apps/api/.env
# - apps/web/.env.local
# - apps/worker/.env
#
# Keep root .env limited to shared local orchestration overrides.

WEB_PORT=17720
API_PORT=17721
LIVEKIT_PORT=17722
LIVEKIT_SIGNAL_PORT=17723
DB_PORT=17724
VALKEY_PORT=17725
OAUTH_PROXY_PORT=17726
LIVEKIT_RTC_PORT_RANGE=17730-17930

COOKIE_SECRET=local-dev-cookie-secret
GOOGLE_CLIENT_ID=local-dev-client-id
GOOGLE_CLIENT_SECRET=local-dev-client-secret
ROOM_AI_API_BASE_URL=http://localhost:17721
