# Root dev orchestration environment
#
# Primary application env files:
#   apps/api/.env
#   apps/web/.env.local
#   apps/worker/.env
#
# Keep this file limited to Docker Compose orchestration overrides.

# --- Port assignments (avoid host collisions) ---
# docker-compose.dev.yml (web), scripts/dev/run-web-dev.mjs
WEB_PORT=17760
# scripts/dev/run-api-dev.mjs
API_PORT=17721
# docker-compose.yml (livekit)
LIVEKIT_PORT=17722
# docker-compose.yml (db)
DB_PORT=17724
# docker-compose.yml (valkey)
VALKEY_PORT=17725
# docker-compose.yml (livekit, UDP media)
LIVEKIT_RTC_PORT_RANGE=17730-17750

# --- Domain / TLS (production only) ---
# Traefik Host() routing — leave "localhost" for local dev
DOMAIN=localhost
# Let's Encrypt email for TLS certificate issuance (required for production)
ACME_EMAIL=

# --- LiveKit client URL ---
# Production: wss://your-domain.com/rtc (Traefik routes /rtc to LiveKit via TLS)
# Local dev:  ws://localhost:17722
ECHOLORE_PUBLIC_LIVEKIT_URL=ws://localhost:17722

# --- TURN server (production) ---
# docker-compose.yml (livekit TURN)
# REQUIRED for production: set to the domain used for TURN TLS (e.g. turn.example.com)
# Without this, TURN TLS routing via Traefik will not function correctly.
LIVEKIT_TURN_DOMAIN=turn.example.com
LIVEKIT_TURN_TLS_PORT=5349

# --- Docker Compose required secrets ---
# docker-compose.yml (db, api), bootstrap-check.yml (db, api)
DB_PASSWORD=wiki_password
# docker-compose.yml (livekit, livekit-egress, api), bootstrap-check.yml
LIVEKIT_API_KEY=devkey
# docker-compose.yml (livekit, livekit-egress, api), bootstrap-check.yml
LIVEKIT_API_SECRET=secret
# docker-compose.yml (api), bootstrap-check.yml (api)
AUTH_SECRET=local-dev-auth-secret
# docker-compose.yml (api, worker)
ROOM_AI_WORKER_SECRET=local-dev-worker-secret
